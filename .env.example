# ============ 存储(二选一,推荐 R2)============

# Cloudflare R2:免费 10GB + 出口流量免费。
# 只需手填下面两行,然后 npm run setup 会自动补齐其余(建 bucket/公开域名/口令/部署播放器):
#   R2_ACCOUNT_ID  Cloudflare Dash 首页右侧栏的 Account ID
#   R2_API_TOKEN   建一个"存储+部署"双权限 token:
#                  https://dash.cloudflare.com/?to=/:account/api-tokens
#                  → Create Token → Create Custom Token → 加两条权限:
#                    Account · Workers R2 Storage · Edit
#                    Account · Cloudflare Pages  · Edit
#                  (只给 R2 权限也行,但部署播放器那步会要求 npx wrangler login)
R2_ACCOUNT_ID=
R2_API_TOKEN=
# ↓ 以下由 npm run setup 自动写入,无需手填
R2_PUBLIC_BASE=

# Supabase Storage:免费 1GB(不填 R2 时使用)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============ LLM(可选,不填则跳过改写直接朗读原文)============

# OpenAI 兼容平台(优先):laozhang.ai / OpenRouter / 任何 /chat/completions 端点
LLM_API_KEY=
LLM_BASE_URL=https://api.laozhang.ai/v1
LLM_MODEL=gemini-3-flash-preview

# Google Gemini 直连(LLM_API_KEY 失败时的回落通道)
GEMINI_API_KEY=

# ============ 播放器(由 npm run setup 自动写入)============
# LWR_ADMIN_TOKEN  设置页管理口令(setup 自动生成并同步到 Pages)
# PAGES_PROJECT    Cloudflare Pages 项目名(setup 自动生成 lwr-xxxx)
LWR_ADMIN_TOKEN=
PAGES_PROJECT=
